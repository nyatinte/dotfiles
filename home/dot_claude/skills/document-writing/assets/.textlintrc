{
  "rules": {
    "@textlint-ja/preset-ai-writing": true,
    "preset-ja-spacing": {
      "ja-space-between-half-and-full-width": {
        "space": ["alphabets"]
      },
      "ja-space-around-code": {
        "before": true,
        "after": true
      },
      "ja-space-around-link": {
        "before": true,
        "after": true
      }
    }
  }
}
